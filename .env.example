# Dev-only API keys, loaded by Vite (and vitest) in dev mode.
#
# Copy this file to `.env.local` (gitignored via `*.local`) and fill in the
# values. These seed the default providers for an out-of-the-box dev
# experience; they are empty in production builds. Never commit real keys —
# the pre-commit secret scanner (scripts/scan-secrets.ts) will block it.

VITE_DEV_OPENROUTER_KEY=
VITE_DEV_GOOGLE_AI_STUDIO_KEY=

# The LLM provider/model catalog is seeded from a JSON file chosen at build
# time. `APP_CONFIG` (a project-relative or absolute path) overrides the
# default, which is `src/assets/config/app-config.dev.json` under `vite serve`
# and `src/assets/config/app-config.prod.json` when bundling. NOTE: this is read
# from the *shell* environment in vite.config.ts (not loaded from this .env
# file), e.g.
#   APP_CONFIG=src/assets/config/app-config.prod.json pnpm dev
# The committed catalog files ship empty API keys; the dev keys above overlay
# onto them at seed time.
